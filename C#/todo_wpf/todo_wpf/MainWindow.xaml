<Window x:Class="todo_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:todo_wpf"
        Title="ToDo App" Height="450" Width="400">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Keresés:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <TextBox Grid.Column="1" x:Name="TB_Search" TextChanged="TB_Search_TextChanged" VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="X" Width="25" Click="BTN_ClearSearch_Click" Margin="5,0,0,0" />
        </Grid>

        <ListBox Grid.Row="1" x:Name="LB" SelectionChanged="LB_SelectionChanged" Margin="0,0,0,5">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:ToDoItem}">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsCompleted}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Description}" VerticalAlignment="Center" Margin="5,0,0,0" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBox Grid.Row="2" x:Name="TB_Editor" Margin="0,0,0,5" />

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Mentés" Click="BTN_Save_Click" Margin="0,0,2.5,0" />
            <Button Grid.Column="1" Content="Törlés" Click="BTN_Delete_Click" Margin="2.5,0,0,0" />
        </Grid>
    </Grid>
</Window>